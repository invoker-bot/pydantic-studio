<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>pydantic-studio — {{ schema_name }}</title>
  <link rel="stylesheet" href="/static/studio.css">
  <script src="/static/htmx.min.js"></script>
</head>
<body>
  <!-- Heartbeat poll: pings /heartbeat on load and every 10s thereafter.
       When the tab closes, pings stop and the server's watchdog flips
       ``cancelled`` after ``heartbeat_timeout_seconds`` of silence so
       ``run_html_app`` doesn't run forever. -->
  <div hx-get="/heartbeat" hx-trigger="load, every 10s" hx-swap="none"
       style="display:none" aria-hidden="true"></div>
  <header>
    <h1>{{ schema_name }}</h1>
  </header>
  <main>
    <aside id="sidebar">
      <ul>
        {% for path, label in groups %}
        <li><a href="#" data-group-path="{{ path }}">{{ label }}</a></li>
        {% endfor %}
      </ul>
    </aside>
    <section id="form">
      {% include "form.html.jinja" %}
    </section>
    <section id="preview">
      <pre id="preview-content">{{ preview }}</pre>
    </section>
  </main>
</body>
</html>
