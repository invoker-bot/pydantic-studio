# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
/dist/
*.egg-info/
.venv/
.dist-smoke*/
.eggs/

# Frontend (Vite + pnpm) - frontend/.gitignore is authoritative,
# this is just a guard against tools accidentally writing to the root.
/frontend/node_modules/

# Environments
.env
.envrc

# Testing
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.hypothesis/

# Type checking
.mypy_cache/
.pyright/

# Editors
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# uv lock file (library project — regenerated per-environment)
uv.lock

# Local verification / debug scripts
verify_spec.py

# pydantic-studio
.pydantic-studio.draft.json

# mkdocs build output (root-level only; docs/site/ holds the docs source)
/site/

# Superpowers brainstorming mockups
.superpowers/

# Codex desktop local environment metadata. Keep tracked .codex assets explicit.
.codex/environments/
